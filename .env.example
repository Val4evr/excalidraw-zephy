# Copy to .env and fill in.
# Generate ADMIN_API_KEY with:  openssl rand -hex 32
ADMIN_API_KEY=
PUBLIC_BASE_URL=https://draw.proklov.dev
# (MCP_INSTALL_TEMPLATE was removed — the dashboard's install section now
# composes snippets for Claude Code, Codex, Cursor, generic stdio, and
# claude.ai client-side from PUBLIC_BASE_URL + the picked room id.)
# Optional: when someone visits the bare canvas URL (no /r/<id>), 302 to this URL.
# Use http://zephy:5000 to send yourself to the dashboard from the bare draw.proklov.dev URL.
# Note: this target must be reachable for the visitor — friends without Tailscale will get a
# DNS error if you point this at zephy. Leave blank to keep the default 404 behavior.
ROOT_REDIRECT_URL=http://zephy:5000
# Optional auto-snapshot tuning. Defaults: every 10 min, keep 15 newest auto-* per room.
# Set AUTO_SNAPSHOT_INTERVAL_MS=0 to disable.
# AUTO_SNAPSHOT_INTERVAL_MS=600000
# AUTO_SNAPSHOT_KEEP=15
# Optional: set to "false" to disable bearer-token auth on /mcp. Lets claude.ai's
# OAuth-only connector dialog attach without any auth dance. Security collapses
# to "room-id is the secret" — same model as /r/<id> links. Default: auth required.
# MCP_REQUIRE_AUTH=true
