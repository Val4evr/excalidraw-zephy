# Copy to .env and fill in.
# Generate ADMIN_API_KEY with:  openssl rand -hex 32
ADMIN_API_KEY=
PUBLIC_BASE_URL=https://draw.proklov.dev
# Optional: shown in dashboard's "Copy install command". {{ROOM_ID}} is substituted.
MCP_INSTALL_TEMPLATE=claude mcp add excalidraw -s user --env ROOM_ID={{ROOM_ID}} --env EXPRESS_SERVER_URL=http://zephy:3000 -- npx -y --package=github:Val4evr/excalidraw-zephy excalidraw-mcp
